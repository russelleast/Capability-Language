{
  "name": "dcl-vscode-extension",
  "displayName": "Declarative Capability Language (DCL)",
  "description": "Compiler-backed VS Code language support and architecture navigation for Declarative Capability Language files.",
  "version": "0.5.6",
  "publisher": "dcl",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/russelleast/Capability-Language.git",
    "directory": "tools/vscode-extension"
  },
  "bugs": {
    "url": "https://github.com/russelleast/Capability-Language/issues"
  },
  "engines": {
    "vscode": "^1.86.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "icon": "resources/dcl-extension.png",
  "keywords": [
    "dcl",
    "declarative capability language",
    "capability",
    "architecture",
    "compiler",
    "diagnostics"
  ],
  "activationEvents": [
    "onLanguage:dcl",
    "onCommand:dcl.compileCurrentFile",
    "onCommand:dcl.compileWorkspace",
    "onCommand:dcl.showSemanticSummary",
    "onCommand:dcl.showCompilerInfo",
    "onCommand:dcl.showLspFeatureStatus",
    "onCommand:dcl.openGraphWorkspace",
    "onCommand:dcl.exportCurrentGraph",
    "onCommand:dcl.formatDocument",
    "onCommand:dcl.refreshExplorer",
    "onCommand:dcl.revealSemanticItemInSource",
    "onCommand:dcl.navigateSymbol",
    "onCommand:dcl.findRelatedElements",
    "onCommand:dcl.openSemanticInspector",
    "onCommand:dcl.focusGraphFromExplorer",
    "onCommand:dcl.showArchitectureOverview",
    "onCommand:dcl.showCapabilityGraph",
    "onCommand:dcl.showContextMap",
    "onCommand:dcl.showEventFlowGraph",
    "onCommand:dcl.showLifecycleGraph",
    "onView:dclSemanticSummary",
    "onView:dclExplorer"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "dcl",
        "aliases": [
          "DCL",
          "Declarative Capability Language"
        ],
        "extensions": [
          ".dcl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "dcl",
        "scopeName": "source.dcl",
        "path": "./syntaxes/dcl.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "dcl",
        "path": "./snippets/dcl.json"
      }
    ],
    "iconThemes": [
      {
        "id": "dcl-file-icons",
        "label": "DCL File Icons",
        "path": "./resources/dcl-file-theme.json"
      }
    ],
    "commands": [
      {
        "command": "dcl.compileCurrentFile",
        "title": "DCL: Compile Current File",
        "category": "DCL"
      },
      {
        "command": "dcl.compileWorkspace",
        "title": "DCL: Compile Workspace",
        "category": "DCL",
        "icon": "$(play)"
      },
      {
        "command": "dcl.showSemanticSummary",
        "title": "DCL: Show Semantic Summary",
        "category": "DCL"
      },
      {
        "command": "dcl.showCompilerInfo",
        "title": "DCL: Show Compiler Info",
        "category": "DCL"
      },
      {
        "command": "dcl.showLspFeatureStatus",
        "title": "DCL: Show LSP Feature Status",
        "category": "DCL"
      },
      {
        "command": "dcl.openGraphWorkspace",
        "title": "DCL: Open Graph Workspace",
        "category": "DCL"
      },
      {
        "command": "dcl.exportCurrentGraph",
        "title": "DCL: Export Current Graph",
        "category": "DCL"
      },
      {
        "command": "dcl.formatDocument",
        "title": "DCL: Format Document",
        "category": "DCL"
      },
      {
        "command": "dcl.refreshExplorer",
        "title": "DCL: Refresh Explorer",
        "category": "DCL",
        "icon": "$(refresh)"
      },
      {
        "command": "dcl.revealSemanticItemInSource",
        "title": "DCL: Reveal Semantic Item in Source",
        "category": "DCL"
      },
      {
        "command": "dcl.navigateSymbol",
        "title": "DCL: Navigate Symbol",
        "category": "DCL"
      },
      {
        "command": "dcl.findRelatedElements",
        "title": "DCL: Find Related Elements",
        "category": "DCL"
      },
      {
        "command": "dcl.openSemanticInspector",
        "title": "DCL: Open Semantic Inspector",
        "category": "DCL"
      },
      {
        "command": "dcl.focusGraphFromExplorer",
        "title": "DCL: Focus in Graph Workspace",
        "category": "DCL"
      },
      {
        "command": "dcl.showArchitectureOverview",
        "title": "DCL: Show Architecture Overview",
        "category": "DCL"
      },
      {
        "command": "dcl.showCapabilityGraph",
        "title": "DCL: Show Capability Graph",
        "category": "DCL"
      },
      {
        "command": "dcl.showContextMap",
        "title": "DCL: Show Context Map",
        "category": "DCL"
      },
      {
        "command": "dcl.showEventFlowGraph",
        "title": "DCL: Show Event Flow Graph",
        "category": "DCL"
      },
      {
        "command": "dcl.showLifecycleGraph",
        "title": "DCL: Show Lifecycle Graph",
        "category": "DCL"
      }
    ],
    "configuration": {
      "title": "DCL",
      "properties": {
        "dcl.compilerPath": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional path to a custom DCL compiler executable. Leave empty to use the bundled compiler for supported platforms, falling back to `dcl` on PATH. The value may include fixed arguments, for example `go run ./cmd/dcl`."
        },
        "dcl.compileOnSave": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "Legacy compile-on-save toggle. If `dcl.compileOnSaveMode` is not explicitly configured, `true` maps to `workspace` and `false` maps to `off`."
        },
        "dcl.compileOnSaveMode": {
          "type": "string",
          "enum": [
            "workspace",
            "file",
            "off"
          ],
          "default": "workspace",
          "markdownDescription": "Controls compile-on-save for `.dcl` files. `workspace` compiles all workspace DCL files, `file` compiles only the saved file, and `off` disables compile-on-save."
        },
        "dcl.graph.followSourceSelection": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "When enabled, moving the cursor inside compiler-known DCL semantic items focuses the matching node in the open Graph Workspace."
        },
        "dcl.graph.autoRevealFromSource": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "When enabled, moving the cursor inside compiler-known DCL semantic items can reveal the Graph Workspace. Disabled by default so manually switching to source does not jump back to the graph."
        },
        "dcl.languageServer.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Enable the experimental DCL Language Server. Disabled by default; existing compiler-backed extension behavior remains unchanged when this is off."
        },
        "dcl.languageServer.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Optional path to a custom `dcl-lsp` executable."
        },
        "dcl.languageServer.trace": {
          "type": "string",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "markdownDescription": "Controls experimental DCL Language Server protocol logging."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dclExplorerContainer",
          "title": "DCL Explorer",
          "icon": "./resources/dcl.svg"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "dclSemanticSummary",
          "name": "DCL Semantic Summary",
          "when": "resourceLangId == dcl"
        }
      ],
      "dclExplorerContainer": [
        {
          "id": "dclExplorer",
          "name": "DCL Explorer"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "dcl.compileCurrentFile",
          "when": "editorLangId == dcl"
        },
        {
          "command": "dcl.compileWorkspace"
        },
        {
          "command": "dcl.showSemanticSummary",
          "when": "editorLangId == dcl"
        },
        {
          "command": "dcl.showCompilerInfo"
        },
        {
          "command": "dcl.formatDocument",
          "when": "editorLangId == dcl"
        },
        {
          "command": "dcl.refreshExplorer"
        },
        {
          "command": "dcl.openGraphWorkspace"
        },
        {
          "command": "dcl.navigateSymbol"
        },
        {
          "command": "dcl.findRelatedElements"
        },
        {
          "command": "dcl.openSemanticInspector"
        },
        {
          "command": "dcl.exportCurrentGraph"
        },
        {
          "command": "dcl.showArchitectureOverview"
        },
        {
          "command": "dcl.showCapabilityGraph"
        },
        {
          "command": "dcl.showContextMap"
        },
        {
          "command": "dcl.showEventFlowGraph"
        },
        {
          "command": "dcl.showLifecycleGraph"
        },
        {
          "command": "dcl.revealSemanticItemInSource",
          "when": "false"
        },
        {
          "command": "dcl.focusGraphFromExplorer",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "dcl.refreshExplorer",
          "when": "view == dclExplorer",
          "group": "navigation"
        },
        {
          "command": "dcl.compileWorkspace",
          "when": "view == dclExplorer",
          "group": "navigation@1"
        },
        {
          "command": "dcl.openGraphWorkspace",
          "when": "view == dclExplorer",
          "group": "navigation@2"
        }
      ],
      "view/item/context": [
        {
          "command": "dcl.showArchitectureOverview",
          "when": "view == dclExplorer && viewItem == dclExplorer.context",
          "group": "inline@1"
        },
        {
          "command": "dcl.showArchitectureOverview",
          "when": "view == dclExplorer && viewItem == dclExplorer.context.located",
          "group": "inline@1"
        },
        {
          "command": "dcl.focusGraphFromExplorer",
          "when": "view == dclExplorer && viewItem =~ /dclExplorer\\.(capability|context|event|lifecycle).*/",
          "group": "navigation"
        },
        {
          "command": "dcl.showContextMap",
          "when": "view == dclExplorer && viewItem == dclExplorer.context",
          "group": "inline"
        },
        {
          "command": "dcl.showContextMap",
          "when": "view == dclExplorer && viewItem == dclExplorer.context.located",
          "group": "inline"
        },
        {
          "command": "dcl.showContextMap",
          "when": "view == dclExplorer && viewItem == dclExplorer.contexts",
          "group": "inline"
        },
        {
          "command": "dcl.showCapabilityGraph",
          "when": "view == dclExplorer && viewItem == dclExplorer.capability.located",
          "group": "inline"
        },
        {
          "command": "dcl.showCapabilityGraph",
          "when": "view == dclExplorer && viewItem == dclExplorer.capability",
          "group": "inline"
        },
        {
          "command": "dcl.showCapabilityGraph",
          "when": "view == dclExplorer && viewItem == dclExplorer.capability.located.lifecycle",
          "group": "inline"
        },
        {
          "command": "dcl.showCapabilityGraph",
          "when": "view == dclExplorer && viewItem == dclExplorer.capability.lifecycle",
          "group": "inline"
        },
        {
          "command": "dcl.showCapabilityGraph",
          "when": "view == dclExplorer && viewItem == dclExplorer.capability.events",
          "group": "inline"
        },
        {
          "command": "dcl.showCapabilityGraph",
          "when": "view == dclExplorer && viewItem == dclExplorer.capability.located.events",
          "group": "inline"
        },
        {
          "command": "dcl.showCapabilityGraph",
          "when": "view == dclExplorer && viewItem == dclExplorer.capability.lifecycle.events",
          "group": "inline"
        },
        {
          "command": "dcl.showCapabilityGraph",
          "when": "view == dclExplorer && viewItem == dclExplorer.capability.located.lifecycle.events",
          "group": "inline"
        },
        {
          "command": "dcl.showEventFlowGraph",
          "when": "view == dclExplorer && viewItem == dclExplorer.capability.events",
          "group": "inline@2"
        },
        {
          "command": "dcl.showEventFlowGraph",
          "when": "view == dclExplorer && viewItem == dclExplorer.capability.located.events",
          "group": "inline@2"
        },
        {
          "command": "dcl.showEventFlowGraph",
          "when": "view == dclExplorer && viewItem == dclExplorer.capability.lifecycle.events",
          "group": "inline@2"
        },
        {
          "command": "dcl.showEventFlowGraph",
          "when": "view == dclExplorer && viewItem == dclExplorer.capability.located.lifecycle.events",
          "group": "inline@2"
        },
        {
          "command": "dcl.showEventFlowGraph",
          "when": "view == dclExplorer && viewItem == dclExplorer.event",
          "group": "inline"
        },
        {
          "command": "dcl.showEventFlowGraph",
          "when": "view == dclExplorer && viewItem == dclExplorer.event.located",
          "group": "inline"
        },
        {
          "command": "dcl.showEventFlowGraph",
          "when": "view == dclExplorer && viewItem == dclExplorer.events",
          "group": "inline"
        },
        {
          "command": "dcl.showLifecycleGraph",
          "when": "view == dclExplorer && viewItem == dclExplorer.capability.located.lifecycle",
          "group": "inline@1"
        },
        {
          "command": "dcl.showLifecycleGraph",
          "when": "view == dclExplorer && viewItem == dclExplorer.capability.lifecycle",
          "group": "inline@1"
        },
        {
          "command": "dcl.showLifecycleGraph",
          "when": "view == dclExplorer && viewItem == dclExplorer.capability.lifecycle.events",
          "group": "inline@1"
        },
        {
          "command": "dcl.showLifecycleGraph",
          "when": "view == dclExplorer && viewItem == dclExplorer.capability.located.lifecycle.events",
          "group": "inline@1"
        },
        {
          "command": "dcl.showLifecycleGraph",
          "when": "view == dclExplorer && viewItem == dclExplorer.lifecycle",
          "group": "inline"
        }
      ],
      "editor/context": [
        {
          "command": "dcl.compileCurrentFile",
          "when": "editorLangId == dcl",
          "group": "navigation"
        },
        {
          "command": "dcl.showSemanticSummary",
          "when": "editorLangId == dcl",
          "group": "navigation"
        },
        {
          "command": "dcl.formatDocument",
          "when": "editorLangId == dcl",
          "group": "1_modification"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "tsc -p ./ --noEmit",
    "copy:vendor": "node scripts/copy-vendor-assets.mjs",
    "build:compiler-binaries": "node scripts/build-compiler-binaries.mjs",
    "build:lsp": "node scripts/build-local-lsp.mjs",
    "package": "vsce package",
    "package:smoke": "npm run build:compiler-binaries && npm run copy:vendor && npm run compile && vsce package --out /tmp/dcl-vscode-extension-smoke.vsix",
    "test": "vitest run",
    "test:watch": "vitest",
    "vscode:prepublish": "npm run build:compiler-binaries && npm run copy:vendor && npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "@types/vscode": "^1.86.0",
    "@vscode/vsce": "^3.9.2",
    "cytoscape": "^3.34.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.9"
  }
}
