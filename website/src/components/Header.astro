---
import { languageLabel, languageStatus } from "../config/version";

const base = import.meta.env.BASE_URL.replace(/\/$/, "");
const path = (href) => `${base}${href}`;

const navItems = [
  { href: "/", label: "Home" },
  { href: "/why-dcl/", label: "Why DCL" },
  { href: "/learn/", label: "Learn" },
  { href: "/guides/", label: "Guides" },
  { href: "/examples/", label: "Examples" },
  { href: "/docs/", label: "Reference" },
  { href: "/tooling/", label: "Tooling" },
  { href: "/playground/", label: "Playground" },
];
---

<header class="site-header">
  <nav class="nav" aria-label="Primary navigation">
    <a class="brand" href={path("/")}>
      <span class="brand-mark">DCL</span>
      <span class="brand-name">Declarative Capability Language</span>
      <span class="version-pill">{languageLabel}</span>
    </a>
    <div class="nav-links">
      {navItems.map((item) => <a href={path(item.href)}>{item.label}</a>)}
      <a href="https://github.com/russelleast/Capability-Language">GitHub</a>
    </div>
  </nav>
  <div class="status-bar">
    <span>{languageLabel}</span>
    <span>Status: {languageStatus}</span>
  </div>
</header>
