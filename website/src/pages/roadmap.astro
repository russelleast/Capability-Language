---
import DocsLayout from "../layouts/DocsLayout.astro";
import { languageLabel, languageStatus, compilerVersion } from "../config/version";

const frontmatter = {
  title: "Roadmap",
  description: "Current DCL version, implemented capabilities, planned work, and future direction.",
};
---

<DocsLayout frontmatter={frontmatter}>
  <h1>Roadmap</h1>
  <p>
    DCL is a language project. This roadmap summarizes the public repository
    roadmap and keeps near-term website work separate from later tooling.
  </p>

  <h2>Current Version</h2>
  <p><strong>{languageLabel}</strong></p>
  <p>Status: <strong>{languageStatus}</strong></p>
  <p>Compiler: <code>dcl {compilerVersion}</code></p>

  <h2>Implemented</h2>
  <ul>
    <li>Compiler CLI for version, check, and IR output.</li>
    <li>Contexts and cross-context dependencies.</li>
    <li>Policies and policy attachments.</li>
    <li>Local and supervising lifecycles.</li>
    <li>Effects, events, observations, rules, and outcome causation.</li>
    <li>Static documentation website.</li>
  </ul>

  <h2>Planned</h2>
  <ul>
    <li>Playground.</li>
    <li>Visuals.</li>
    <li>VS Code extension.</li>
    <li>Language server.</li>
    <li>MCP server.</li>
  </ul>

  <h2>Future Direction</h2>
  <ul>
    <li>Runtime projections.</li>
    <li>Documentation generation.</li>
    <li>Diagram generation.</li>
  </ul>
</DocsLayout>
