---
import BaseLayout from "../layouts/BaseLayout.astro";
import { compilerVersion, languageLabel } from "../config/version";
import { dclEditorHelpSnippetLabels, dclSnippets } from "../lib/playground/dcl-language";
import { playgroundExamples } from "../lib/playground/examples";
import { sitePath } from "../lib/playground/links";

const initialExample = playgroundExamples[0];
const editorHelpSnippets = dclSnippets.filter((snippet) => dclEditorHelpSnippetLabels.includes(snippet.label));
---

<BaseLayout
  title="DCL Playground"
  description="Try validated DCL examples, edit source, and prepare for browser compiler diagnostics."
>
  <section class="content-wrap playground-page">
    <article class="prose playground-intro">
      <p class="eyebrow">Experimental</p>
      <h1>DCL Playground</h1>
      <p>
        Choose a validated example, edit the DCL source, and use the stable
        compiler adapter boundary that will host browser compilation.
      </p>
      <p class="version-line">
        Current language: <strong>{languageLabel}</strong>. Compiler:
        <code>dcl {compilerVersion}</code>.
      </p>
      <p>
        The website is statically hosted on GitHub Pages. The compiler runs in
        your browser through Go WASM; no backend compile service is used.
      </p>
    </article>

    <div class="playground-shell" data-playground>
      <div class="playground-toolbar">
        <div class="playground-toolbar-main">
          <label class="field-label" for="example-select">
            <span>Example</span>
            <select id="example-select" class="example-select" data-example-select>
              {
                playgroundExamples.map((example) => (
                  <option value={example.id}>{example.title}</option>
                ))
              }
            </select>
          </label>
          <div class="playground-badges">
            <span class="validated-badge">Validated example</span>
            <span class="version-pill">Compiler {compilerVersion}</span>
          </div>
        </div>
        <div class="playground-actions">
          <button class="button secondary control-button" type="button" data-copy-source-button>
            Copy source
          </button>
          <button class="button secondary control-button" type="button" data-copy-diagnostics-button>
            Copy diagnostics
          </button>
          <button class="button secondary control-button" type="button" data-copy-playground-link-button>
            Copy playground link
          </button>
          <button class="button secondary control-button" type="button" data-reset-button>
            Reset
          </button>
          <button class="button primary control-button" type="button" data-compile-button>
            Compile
          </button>
        </div>
      </div>

      <div class="example-meta">
        <p class="example-summary" data-example-summary>
          {initialExample.description}
        </p>
        <p class="example-path" data-example-path>
          Source: <code>{initialExample.path}</code>
        </p>
      </div>

      <div class="playground-grid">
        <div class="editor-panel">
          <div class="pane-heading">
            <label for="source-editor">DCL source</label>
            <div class="editor-actions">
              <button class="button secondary control-button editor-format-button" type="button" data-format-source-button>
                Format
              </button>
              <button class="button secondary control-button editor-suggest-button" type="button" data-show-suggestions-button>
                Show suggestions
              </button>
            </div>
          </div>
          <div class="monaco-editor-host" data-monaco-editor hidden></div>
          <textarea id="source-editor" aria-label="DCL source" spellcheck="false" data-source-editor>{initialExample.source}</textarea>
          <section class="editor-help-panel" aria-labelledby="editor-help-title">
            <div class="editor-help-copy">
              <h2 id="editor-help-title">Editor help</h2>
              <p>
                Autocomplete: macOS <kbd>Option</kbd>+<kbd>Escape</kbd>, Windows/Linux
                <kbd>Ctrl</kbd>+<kbd>Space</kbd>, or the Show suggestions button.
                Format source with <kbd>Shift</kbd>+<kbd>Option</kbd>+<kbd>F</kbd> on macOS,
                <kbd>Shift</kbd>+<kbd>Alt</kbd>+<kbd>F</kbd> on Windows/Linux, or the Format button.
              </p>
              <p>
                Compiler diagnostics appear after pressing Compile. Red and yellow markers come from the DCL compiler.
              </p>
            </div>
            <div class="editor-help-snippets" aria-label="Common snippets">
              <span>Snippets</span>
              {
                editorHelpSnippets.map((snippet) => (
                  <a href={sitePath(`/docs/#${snippet.label}`)}>
                    <code>{snippet.label}</code>
                  </a>
                ))
              }
            </div>
          </section>
          <p class="editor-fallback-message" data-editor-fallback-message hidden>
            Monaco editor could not load. The fallback editor is available below.
          </p>
        </div>

        <aside class="diagnostics-panel" aria-live="polite">
          <div class="pane-heading">
            <h2>Compiler results</h2>
            <span>Compiler</span>
          </div>
          <div class="status-card" data-result-status>
            Ready. Select an example or edit the source.
          </div>
          <section class="compiler-results" data-compiler-results hidden>
            <div class="result-tabs" role="tablist" aria-label="Compiler result views">
              <button class="result-tab" type="button" role="tab" aria-selected="true" data-result-tab="summary">
                Semantic Summary
              </button>
              <button class="result-tab" type="button" role="tab" aria-selected="false" data-result-tab="map">
                Capability Map
              </button>
              <button class="result-tab" type="button" role="tab" aria-selected="false" data-result-tab="flow">
                Flow
              </button>
              <button class="result-tab" type="button" role="tab" aria-selected="false" data-result-tab="analysis">
                Analysis
              </button>
              <button class="result-tab" type="button" role="tab" aria-selected="false" data-result-tab="advanced">
                Advanced
              </button>
            </div>
            <section class="summary-output result-panel" data-summary-output data-result-panel="summary">
              <h2>Semantic Summary</h2>
              <p>The compiler summary will appear here after a successful compile.</p>
            </section>
            <section class="capability-map-output result-panel" data-result-panel="map" hidden>
              <h2>Capability Map</h2>
              <p>The capability map will appear here after a successful compile.</p>
            </section>
            <section class="flow-output result-panel" data-result-panel="flow" hidden>
              <h2>Flow</h2>
              <p>Lifecycle and event flow will appear here after a successful compile.</p>
            </section>
            <section class="analysis-output result-panel" data-result-panel="analysis" hidden>
              <h2>Analysis</h2>
              <p>Compiler reasoning will appear here after a successful compile.</p>
            </section>
            <section class="advanced-output result-panel" data-result-panel="advanced" hidden>
              <h2>Advanced: View compiler output</h2>
              <pre><code data-compiler-output>{}</code></pre>
            </section>
          </section>
          <div class="diagnostics-section">
            <div class="pane-heading">
              <h2>Diagnostics</h2>
              <span data-diagnostics-count>No run</span>
            </div>
            <div class="diagnostics-output" data-diagnostics-output>
              <p class="empty-state">No compile run yet.</p>
            </div>
          </div>
        </aside>
      </div>
    </div>

    <section class="visuals-section" aria-labelledby="visuals-title" data-visuals-section>
      <div class="visuals-heading">
        <div>
          <p class="eyebrow">Architecture View</p>
          <h2 id="visuals-title">Visuals</h2>
        </div>
        <p data-visuals-status>Compile DCL source to generate visuals.</p>
      </div>
      <div class="visual-tabs" role="tablist" aria-label="Playground visual views">
        <button class="visual-tab" type="button" role="tab" aria-selected="true" data-visual-tab="heatmap">
          Context Heat Map
        </button>
        <button class="visual-tab" type="button" role="tab" aria-selected="false" data-visual-tab="capability-flow">
          Capability Flow
        </button>
        <button class="visual-tab" type="button" role="tab" aria-selected="false" data-visual-tab="lifecycle-flow">
          Lifecycle/Event Flow
        </button>
      </div>
      <div class="visual-panel" data-visual-panel="heatmap">
        <p class="visual-empty">Compile DCL source to generate visuals.</p>
      </div>
      <div class="visual-panel" data-visual-panel="capability-flow" hidden>
        <p class="visual-empty">Compile DCL source to generate visuals.</p>
      </div>
      <div class="visual-panel" data-visual-panel="lifecycle-flow" hidden>
        <p class="visual-empty">Compile DCL source to generate visuals.</p>
      </div>
    </section>

    <article class="prose playground-notes">
      <p>
        Continue with <a href={sitePath("/examples/")}>Examples</a> or the
        <a href={sitePath("/docs/")}>Reference</a>.
      </p>
    </article>
  </section>

  <script>
    import { compileDcl, type Diagnostic } from "../lib/playground/compiler";
    import { formatDcl } from "../lib/playground/formatDcl";
    import { playgroundExamples } from "../lib/playground/examples";
    import { playgroundExamplePath } from "../lib/playground/links";
    import { summarizeCompilerOutput, type CapabilityItemKind, type CapabilitySummary, type SemanticSummary, type SourceLocation } from "../lib/playground/semantic-summary";
    import { createVisualModel, type VisualCapability, type VisualContext, type VisualModel } from "../lib/playground/visual-model";
    import type { DclEditorController } from "../lib/playground/dcl-editor";

    const select = document.querySelector("[data-example-select]") as HTMLSelectElement | null;
    const editor = document.querySelector("[data-source-editor]") as HTMLTextAreaElement | null;
    const monacoHost = document.querySelector("[data-monaco-editor]") as HTMLElement | null;
    const editorFallbackMessage = document.querySelector("[data-editor-fallback-message]");
    const resetButton = document.querySelector("[data-reset-button]") as HTMLButtonElement | null;
    const compileButton = document.querySelector("[data-compile-button]") as HTMLButtonElement | null;
    const formatSourceButton = document.querySelector("[data-format-source-button]") as HTMLButtonElement | null;
    const showSuggestionsButton = document.querySelector("[data-show-suggestions-button]") as HTMLButtonElement | null;
    const copySourceButton = document.querySelector("[data-copy-source-button]") as HTMLButtonElement | null;
    const copyDiagnosticsButton = document.querySelector("[data-copy-diagnostics-button]") as HTMLButtonElement | null;
    const copyPlaygroundLinkButton = document.querySelector("[data-copy-playground-link-button]") as HTMLButtonElement | null;
    const summary = document.querySelector("[data-example-summary]");
    const sourcePath = document.querySelector("[data-example-path]");
    const status = document.querySelector("[data-result-status]");
    const diagnostics = document.querySelector("[data-diagnostics-output]");
    const diagnosticsCount = document.querySelector("[data-diagnostics-count]");
    const compilerResults = document.querySelector("[data-compiler-results]");
    const summaryOutput = document.querySelector("[data-summary-output]");
    const mapOutput = document.querySelector("[data-result-panel='map']");
    const flowOutput = document.querySelector("[data-result-panel='flow']");
    const analysisOutput = document.querySelector("[data-result-panel='analysis']");
    const advancedOutput = document.querySelector("[data-result-panel='advanced']");
    const compilerOutput = document.querySelector("[data-compiler-output]");
    const resultTabs = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-result-tab]"));
    const resultPanels = Array.from(document.querySelectorAll<HTMLElement>("[data-result-panel]"));
    const visualTabs = Array.from(document.querySelectorAll<HTMLButtonElement>("[data-visual-tab]"));
    const visualPanels = Array.from(document.querySelectorAll<HTMLElement>("[data-visual-panel]"));
    const visualsStatus = document.querySelector("[data-visuals-status]");
    const heatMapOutput = document.querySelector<HTMLElement>("[data-visual-panel='heatmap']");
    const visualCapabilityFlowOutput = document.querySelector<HTMLElement>("[data-visual-panel='capability-flow']");
    const visualLifecycleFlowOutput = document.querySelector<HTMLElement>("[data-visual-panel='lifecycle-flow']");
    let selectedVisualCapabilityId = "";
    let sourceEditor: Pick<DclEditorController, "getValue" | "setValue" | "setDiagnostics" | "revealSourceLocation" | "formatSource" | "showSuggestions"> = {
      getValue: () => editor?.value ?? "",
      setValue: (value: string) => {
        if (editor) editor.value = value;
      },
      setDiagnostics: () => undefined,
      revealSourceLocation(location: SourceLocation) {
        if (!editor || !hasSourceLocation(location)) return false;
        editor.focus();
        editor.setSelectionRange(editor.value.length, editor.value.length);
        return false;
      },
      formatSource: () => {
        if (!editor) return false;
        const current = editor.value;
        const formatted = formatDcl(current);
        if (formatted === current) return false;
        editor.value = formatted;
        return true;
      },
      showSuggestions: () => editor?.focus(),
    };

    if (editor && monacoHost) {
      import("../lib/playground/dcl-editor")
        .then(({ createDclEditor }) => {
          sourceEditor = createDclEditor(editor, monacoHost);
        })
        .catch(() => {
          monacoHost.hidden = true;
          editor.hidden = false;
          editorFallbackMessage?.removeAttribute("hidden");
        });
    }

    function selectedExample() {
      return playgroundExamples.find((example) => example.id === select?.value) ?? playgroundExamples[0];
    }

    function selectExampleFromUrl() {
      const exampleId = new URLSearchParams(window.location.search).get("example");
      if (!exampleId || !select) return false;
      const example = playgroundExamples.find((item) => item.id === exampleId);
      if (!example) return false;

      select.value = example.id;
      return true;
    }

    function currentPlaygroundLink() {
      return new URL(playgroundExamplePath(selectedExample().id), window.location.origin).toString();
    }

    function updateExampleUrl() {
      const url = new URL(currentPlaygroundLink());
      window.history.replaceState({}, "", `${url.pathname}${url.search}${url.hash}`);
    }

    function setStatus(message: string, state = "idle") {
      if (!status) return;
      status.textContent = message;
      status.setAttribute("data-state", state);
    }

    function renderDiagnostics(result: Awaited<ReturnType<typeof compileDcl>>) {
      if (!diagnostics) return;

      if (result.diagnostics.length === 0) {
        if (diagnosticsCount) diagnosticsCount.textContent = "Clean";
        diagnostics.innerHTML = '<p class="diagnostic-success">No diagnostics. The compiler accepted this source.</p>';
        return;
      }

      const severityCounts = result.diagnostics.reduce(
        (counts, diagnostic) => {
          counts[diagnostic.severity] += 1;
          return counts;
        },
        { error: 0, warning: 0, info: 0 },
      );
      if (diagnosticsCount) {
        diagnosticsCount.textContent = [
          severityCounts.error ? `${severityCounts.error} error${severityCounts.error === 1 ? "" : "s"}` : "",
          severityCounts.warning ? `${severityCounts.warning} warning${severityCounts.warning === 1 ? "" : "s"}` : "",
          severityCounts.info ? `${severityCounts.info} info` : "",
        ].filter(Boolean).join(", ");
      }

      const list = document.createElement("ul");
      list.className = "diagnostic-list";

      for (const diagnostic of result.diagnostics) {
        const item = document.createElement("li");
        item.className = `diagnostic diagnostic-${diagnostic.severity}`;

        const severity = document.createElement("span");
        severity.className = "diagnostic-severity";
        severity.textContent = diagnostic.severity;

        const heading = document.createElement("strong");
        const explanation = explainDiagnostic(diagnostic);
        heading.textContent = explanation.title;

        const message = document.createElement("p");
        message.textContent = diagnostic.message;

        item.append(severity, heading, message);
        item.append(renderDiagnosticExplanation(explanation));

        if (diagnostic.line || diagnostic.column) {
          const location = document.createElement("span");
          location.className = "diagnostic-location";
          location.textContent = `Line ${diagnostic.line ?? "?"}, column ${diagnostic.column ?? "?"}`;
          item.append(location);
        }

        list.append(item);
      }

      diagnostics.replaceChildren(list);
    }

    type DiagnosticExplanation = {
      title: string;
      reason: string;
      impact: string;
      suggestedFix: string;
    };

    type AnalysisProgram = {
      actors?: unknown[];
      capabilities?: AnalysisCapability[];
      contexts?: unknown[];
      effects?: unknown[];
      events?: unknown[];
      policies?: unknown[];
      diagnostics?: Diagnostic[];
    };

    type AnalysisCapability = {
      name?: string;
      intents?: unknown[];
      outcomes?: unknown[];
      invariants?: unknown[];
      effects?: unknown[];
      events?: unknown[];
      emitted_events?: unknown[];
      policies?: unknown[];
      lifecycle?: {
        steps?: unknown[];
        transitions?: unknown[];
        participating_capabilities?: unknown[];
        contributors?: unknown[];
      };
      analysis?: {
        reachable_outcomes?: string[];
        outcome_causes?: unknown[];
        portability?: string;
      };
    };

    function explainDiagnostic(diagnostic: Diagnostic): DiagnosticExplanation {
      const code = diagnostic.code ?? "Compiler diagnostic";
      const normalized = code.toLowerCase();
      const title = code
        .replace(/^DCL_/, "")
        .toLowerCase()
        .split("_")
        .filter(Boolean)
        .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
        .join(" ") || "Compiler diagnostic";

      if (normalized.includes("unknown") || normalized.includes("undefined") || normalized.includes("unresolved")) {
        return {
          title,
          reason: "The compiler could not resolve a referenced DCL symbol from the current context.",
          impact: "Compilation cannot safely connect this declaration to the intended actor, shape, effect, event, policy, outcome, or capability.",
          suggestedFix: "Check the referenced name, declare the missing symbol, or add an explicit context dependency if the symbol lives elsewhere.",
        };
      }

      if (normalized.includes("lifecycle")) {
        return {
          title,
          reason: "The compiler found a lifecycle rule that does not match the declared lifecycle states, triggers, contributors, or ownership.",
          impact: "The lifecycle view may be incomplete until the transition model is valid.",
          suggestedFix: "Review begin, step, end, move, contributor, and trigger declarations for the named lifecycle item.",
        };
      }

      if (normalized.includes("policy")) {
        return {
          title,
          reason: "The compiler found a policy declaration, attachment, or policy causation that cannot be applied as written.",
          impact: "The affected reliability, security, governance, or operational concern may not protect the intended target.",
          suggestedFix: "Check the policy family, concern, target kind, target name, and whether the policy is attached to the capability boundary.",
        };
      }

      if (normalized.includes("duplicate") || normalized.includes("ambiguous") || normalized.includes("conflict")) {
        return {
          title,
          reason: "The compiler found multiple declarations or paths that make the model ambiguous.",
          impact: "The compiler cannot choose one meaning without risking a wrong semantic interpretation.",
          suggestedFix: "Rename or remove the duplicate item, or make the reference more explicit.",
        };
      }

      if (diagnostic.severity === "warning") {
        return {
          title,
          reason: "The compiler accepted the source but found something that may be incomplete, redundant, or surprising.",
          impact: "The model can compile, but the generated summary may not express the intent as clearly as possible.",
          suggestedFix: "Review the warning location and simplify, clarify, or complete the nearby declaration.",
        };
      }

      return {
        title,
        reason: "The compiler reported this while parsing or validating the DCL source.",
        impact: diagnostic.severity === "error" ? "The compiler cannot accept the source until this is fixed." : "The source compiled with additional information from the compiler.",
        suggestedFix: "Use the diagnostic message and source location to inspect the nearby DCL declaration.",
      };
    }

    function renderDiagnosticExplanation(explanation: DiagnosticExplanation) {
      const details = document.createElement("dl");
      details.className = "diagnostic-explanation";
      appendDefinition(details, "Reason", explanation.reason);
      appendDefinition(details, "Impact", explanation.impact);
      appendDefinition(details, "Suggested fix", explanation.suggestedFix);
      return details;
    }

    function renderSummary(result: Awaited<ReturnType<typeof compileDcl>>) {
      if (!summaryOutput) return;

      if (!result.ok || !result.ir) {
        compilerResults?.setAttribute("hidden", "");
        summaryOutput.replaceChildren();
        if (analysisOutput) analysisOutput.replaceChildren();
        renderVisualEmpty("Compile DCL source to generate visuals.");
        return;
      }

      const summary = summarizeCompilerOutput(result.ir);
      compilerResults?.removeAttribute("hidden");
      summaryOutput.replaceChildren(summaryHeading(), summaryIntro(), renderSemanticSummary(summary));
      renderCapabilityMap(summary);
      renderFlow(summary);
      renderAnalysis(summary, result);
      renderVisuals(summary, result.diagnostics);
      activateResultPanel("summary");
    }

    function summaryHeading() {
      const heading = document.createElement("h2");
      heading.textContent = "Semantic Summary";
      return heading;
    }

    function summaryIntro() {
      const intro = document.createElement("p");
      intro.className = "summary-intro";
      intro.textContent = "This is the meaning the compiler derived from your DCL source.";
      return intro;
    }

    function renderSemanticSummary(summary: SemanticSummary) {
      const container = document.createElement("div");
      container.className = "summary-list";

      if (summary.capabilities.length === 0) {
        const empty = document.createElement("p");
        empty.textContent = "No capabilities were found in the compiler output.";
        container.append(empty);
      }

      for (const capability of summary.capabilities) {
        container.append(renderCapabilitySummary(capability));
      }

      if (summary.contexts?.length) {
        container.append(renderSummaryGroup("Contexts", summary.contexts.map((context) => {
          const deps = context.dependencies?.length ? ` depends on ${context.dependencies.join(", ")}` : "";
          return `${context.name}${deps}`;
        })));
      }

      if (summary.dependencies?.length) {
        container.append(renderSummaryGroup("Dependencies", summary.dependencies));
      }

      return container;
    }

    function renderCapabilitySummary(capability: CapabilitySummary) {
      const section = document.createElement("section");
      section.className = "summary-capability";

      const heading = document.createElement("h3");
      heading.textContent = `Capability: ${capability.name}`;
      section.append(heading);

      const groups = document.createElement("div");
      groups.className = "summary-card-grid";
      groups.append(
        renderSummaryGroup("Intents", capability.intents),
        renderSummaryGroup("Actors", capability.actors),
        renderSummaryGroup("Outcomes", capability.outcomes),
        renderSummaryGroup("Rules", capability.rules),
        renderSummaryGroup("Effects", capability.effects),
        renderSummaryGroup("Events", capability.events),
        renderSummaryGroup("Policies", capability.policies),
      );
      section.append(groups);

      if (capability.lifecycle?.steps?.length || capability.lifecycle?.transitions?.length) {
        const lifecycle = document.createElement("div");
        lifecycle.className = "summary-group";
        const label = document.createElement("strong");
        label.textContent = "Lifecycle";
        lifecycle.append(label);
        if (capability.lifecycle.steps?.length) lifecycle.append(renderInlineList("Steps", capability.lifecycle.steps));
        if (capability.lifecycle.transitions?.length) lifecycle.append(renderInlineList("Transitions", capability.lifecycle.transitions));
        section.append(lifecycle);
      }

      return section;
    }

    function renderCapabilityMap(summary: SemanticSummary) {
      if (!mapOutput) return;

      mapOutput.replaceChildren(mapHeading(), mapIntro());

      const map = document.createElement("div");
      map.className = "capability-map";

      if (summary.capabilities.length === 0) {
        const empty = document.createElement("p");
        empty.textContent = "No capabilities were found in the compiler output.";
        map.append(empty);
      }

      for (const capability of summary.capabilities) {
        map.append(renderCapabilityMapCard(capability));
      }

      mapOutput.append(map);
    }

    function mapHeading() {
      const heading = document.createElement("h2");
      heading.textContent = "Capability Map";
      return heading;
    }

    function mapIntro() {
      const intro = document.createElement("p");
      intro.className = "summary-intro";
      intro.textContent = "A plain-language view of how actors, capabilities, outcomes, effects, events, policies, and lifecycles relate.";
      return intro;
    }

    function renderCapabilityMapCard(capability: CapabilitySummary) {
      const card = document.createElement("article");
      card.className = "capability-map-card";

      const heading = document.createElement("h3");
      heading.textContent = capability.name;
      card.append(heading);

      appendMapPath(card, "Actors express intents", [...(capability.actors ?? []), ...(capability.intents ?? [])], capability.name, capability.outcomes);
      if (capability.effects?.length) appendMapPath(card, "Capability causes effects", [capability.name], undefined, capability.effects);
      if (capability.events?.length) appendMapPath(card, "Capability emits events", [capability.name], undefined, capability.events);
      appendMapSection(card, "Rules guide decisions", capability.rules);
      appendMapSection(card, "Policies shape operation", capability.policies);

      const lifecycleItems = [
        ...(capability.lifecycle?.steps?.map((step) => `Step: ${step}`) ?? []),
        ...(capability.lifecycle?.transitions?.map((transition) => `Transition: ${transition}`) ?? []),
      ];
      appendMapSection(card, "Lifecycle progresses through steps", lifecycleItems);

      return card;
    }

    function appendMapPath(parent: HTMLElement, title: string, sources?: string[], center?: string, targets?: string[]) {
      if (!sources?.length && !center && !targets?.length) return;

      const section = document.createElement("section");
      section.className = "capability-map-path";

      const heading = document.createElement("strong");
      heading.textContent = title;
      section.append(heading);

      const path = document.createElement("div");
      path.className = "map-path";
      appendMapNodes(path, sources);
      if (center) appendMapNode(path, center, "capability");
      appendMapNodes(path, targets);
      section.append(path);
      parent.append(section);
    }

    function appendMapNodes(parent: HTMLElement, items?: string[]) {
      for (const item of items ?? []) {
        appendMapNode(parent, item);
      }
    }

    function appendMapNode(parent: HTMLElement, label: string, kind = "default") {
      const node = document.createElement("span");
      node.className = `map-node map-node-${kind}`;
      node.textContent = label;
      parent.append(node);
    }

    function renderFlow(summary: SemanticSummary) {
      if (!flowOutput) return;

      flowOutput.replaceChildren(flowHeading(), flowIntro());

      const flow = document.createElement("div");
      flow.className = "flow-list";
      const flowCapabilities = summary.capabilities.filter(hasFlow);

      if (flowCapabilities.length === 0) {
        const empty = document.createElement("p");
        empty.className = "flow-empty";
        empty.textContent = "No lifecycle transitions were found in this source.";
        flow.append(empty);
      }

      for (const capability of flowCapabilities) {
        flow.append(renderFlowCard(capability));
      }

      flowOutput.append(flow);
    }

    function renderAnalysis(summary: SemanticSummary, result: Awaited<ReturnType<typeof compileDcl>>) {
      if (!analysisOutput) return;

      const program = isObject(result.ir) ? (result.ir as AnalysisProgram) : {};
      analysisOutput.replaceChildren(analysisHeading(), analysisIntro());

      const sections = document.createElement("div");
      sections.className = "analysis-list";
      sections.append(
        renderCompilerSummary(summary, program),
        renderValidationResults(summary, program, result.diagnostics),
        renderCapabilityAnalysis(summary, program),
        renderArchitectureInsights(summary),
        renderDiagnosticAnalysis(result.diagnostics),
      );
      analysisOutput.append(sections);
    }

    function analysisHeading() {
      const heading = document.createElement("h2");
      heading.textContent = "Analysis";
      return heading;
    }

    function analysisIntro() {
      const intro = document.createElement("p");
      intro.className = "summary-intro";
      intro.textContent = "A human-readable view of what the compiler understood, validated, and derived from the current source.";
      return intro;
    }

    function renderCompilerSummary(summary: SemanticSummary, program: AnalysisProgram) {
      const section = analysisSection("Compiler Summary");
      const grid = document.createElement("div");
      grid.className = "analysis-metric-grid";
      const metrics = [
        ["Contexts", summary.contexts?.length ?? program.contexts?.length ?? 0],
        ["Capabilities", summary.capabilities.length],
        ["Actors", program.actors?.length ?? countUnique(summary.capabilities.flatMap((capability) => capability.actors ?? []))],
        ["Policies", program.policies?.length ?? countUnique(summary.capabilities.flatMap((capability) => capability.policies ?? []))],
        ["Effects", program.effects?.length ?? countUnique(summary.capabilities.flatMap((capability) => capability.effects ?? []))],
        ["Events", program.events?.length ?? countUnique(summary.capabilities.flatMap((capability) => capability.events ?? []))],
      ] as const;

      for (const [label, value] of metrics) {
        const card = document.createElement("div");
        card.className = "analysis-metric";
        const number = document.createElement("strong");
        number.textContent = String(value);
        const text = document.createElement("span");
        text.textContent = label;
        card.append(number, text);
        grid.append(card);
      }
      section.append(grid);
      return section;
    }

    function renderValidationResults(summary: SemanticSummary, program: AnalysisProgram, diagnostics: Diagnostic[]) {
      const section = analysisSection("Validation Results");
      const checks = document.createElement("ul");
      checks.className = "analysis-check-list";

      const diagnosticCodes = diagnostics.map((diagnostic) => diagnostic.code ?? "");
      if (diagnostics.length === 0) {
        checks.append(analysisCheck("pass", "No diagnostics reported", "The compiler accepted this source without warnings or errors."));
      }
      if (!diagnosticCodes.some((code) => /UNKNOWN|UNDEFINED|UNRESOLVED/.test(code))) {
        checks.append(analysisCheck("pass", "All referenced symbols resolved", "No unresolved-symbol diagnostics were reported by the compiler."));
      }
      if (program.capabilities?.some((capability) => Array.isArray(capability.analysis?.reachable_outcomes))) {
        const unreachable = program.capabilities.flatMap((capability) => {
          const outcomes = namesFromUnknownItems(capability.outcomes);
          const reachable = new Set(capability.analysis?.reachable_outcomes ?? []);
          return outcomes.filter((outcome) => !reachable.has(outcome));
        });
        checks.append(
          analysisCheck(
            unreachable.length ? "warn" : "pass",
            unreachable.length ? "Some outcomes may not be reachable" : "Outcomes reachable",
            unreachable.length ? `Unreachable outcomes reported by analysis: ${unreachable.join(", ")}.` : "Capability analysis reports declared outcomes as reachable.",
          ),
        );
      }
      if (summary.capabilities.some((capability) => capability.lifecycle)) {
        const lifecycleDiagnostics = diagnostics.filter((diagnostic) => diagnostic.code?.includes("LIFECYCLE"));
        checks.append(
          analysisCheck(
            lifecycleDiagnostics.length ? "warn" : "pass",
            lifecycleDiagnostics.length ? "Lifecycle diagnostics reported" : "Lifecycle valid",
            lifecycleDiagnostics.length
              ? "The compiler emitted lifecycle diagnostics for this source."
              : "No lifecycle diagnostics were reported for declared lifecycle structures.",
          ),
        );
      }
      if (!diagnosticCodes.some((code) => /AMBIG|CONFLICT|DUPLICATE/.test(code))) {
        checks.append(analysisCheck("pass", "No ambiguity detected", "No ambiguity, conflict, or duplicate diagnostics were reported."));
      }

      if (!checks.children.length) {
        checks.append(analysisCheck("info", "No validation facts available", "The compiler output did not include validation facts for this source."));
      }

      section.append(checks);
      return section;
    }

    function renderCapabilityAnalysis(summary: SemanticSummary, program: AnalysisProgram) {
      const section = analysisSection("Capability Analysis");
      const list = document.createElement("div");
      list.className = "analysis-capability-list";
      const capabilitiesByName = new Map((program.capabilities ?? []).map((capability) => [capability.name, capability]));

      if (!summary.capabilities.length) {
        const empty = document.createElement("p");
        empty.className = "empty-state";
        empty.textContent = "No capabilities were found in the compiler output.";
        section.append(empty);
        return section;
      }

      for (const capability of summary.capabilities) {
        const rawCapability = capabilitiesByName.get(capability.name);
        const card = document.createElement("article");
        card.className = "analysis-capability-card";
        const heading = document.createElement("h3");
        heading.textContent = capability.context ? `${capability.context}.${capability.name}` : capability.name;
        card.append(heading);

        const groups = document.createElement("div");
        groups.className = "summary-card-grid";
        groups.append(
          renderSummaryGroup("Intents", capability.intents),
          renderSummaryGroup("Outcomes", capability.outcomes),
          renderSummaryGroup("Rules", capability.rules),
          renderSummaryGroup("Effects", capability.effects),
          renderSummaryGroup("Events", capability.events),
          renderSummaryGroup("Policies", capability.policies),
          renderSummaryGroup("Lifecycle participation", lifecycleParticipation(capability, rawCapability)),
        );
        card.append(groups);

        if (rawCapability?.analysis?.reachable_outcomes?.length || rawCapability?.analysis?.outcome_causes?.length || rawCapability?.analysis?.portability) {
          const reasoning = document.createElement("div");
          reasoning.className = "analysis-reasoning";
          if (rawCapability.analysis.reachable_outcomes?.length) {
            reasoning.append(renderSummaryGroup("Reachable outcomes", rawCapability.analysis.reachable_outcomes));
          }
          if (rawCapability.analysis.outcome_causes?.length) {
            reasoning.append(renderSummaryGroup("Outcome causes", rawCapability.analysis.outcome_causes.map(formatOutcomeCause)));
          }
          if (rawCapability.analysis.portability) {
            reasoning.append(renderSummaryGroup("Portability", [rawCapability.analysis.portability]));
          }
          card.append(reasoning);
        }

        list.append(card);
      }

      section.append(list);
      return section;
    }

    function renderArchitectureInsights(summary: SemanticSummary) {
      const section = analysisSection("Architecture Insights");
      const list = document.createElement("ul");
      list.className = "analysis-insight-list";
      const capabilities = summary.capabilities;

      const mostEffects = maxBy(capabilities, (capability) => capability.effects?.length ?? 0);
      if (mostEffects && (mostEffects.effects?.length ?? 0) > 0) {
        list.append(analysisInsight(`${mostEffects.name} has the most effects (${mostEffects.effects?.length ?? 0}).`));
      }

      const mostOutcomes = maxBy(capabilities, (capability) => capability.outcomes?.length ?? 0);
      if (mostOutcomes && (mostOutcomes.outcomes?.length ?? 0) > 0) {
        list.append(analysisInsight(`${mostOutcomes.name} has the most outcomes (${mostOutcomes.outcomes?.length ?? 0}).`));
      }

      const contextCounts = capabilities.reduce((counts, capability) => {
        const context = capability.context ?? "Unscoped";
        counts.set(context, (counts.get(context) ?? 0) + 1);
        return counts;
      }, new Map<string, number>());
      const densestContext = Array.from(contextCounts.entries()).sort((a, b) => b[1] - a[1])[0];
      if (densestContext) {
        list.append(analysisInsight(`${densestContext[0]} has the highest capability density (${densestContext[1]}).`));
      }

      if (!list.children.length) {
        list.append(analysisInsight("No architecture insights are derivable from this compiler output yet."));
      }

      section.append(list);
      return section;
    }

    function renderDiagnosticAnalysis(diagnostics: Diagnostic[]) {
      const section = analysisSection("Diagnostic Explanations");
      if (!diagnostics.length) {
        const clean = document.createElement("p");
        clean.className = "diagnostic-success";
        clean.textContent = "No diagnostics. The compiler accepted this source.";
        section.append(clean);
        return section;
      }

      const list = document.createElement("ul");
      list.className = "diagnostic-list";
      for (const diagnostic of diagnostics) {
        const item = document.createElement("li");
        item.className = `diagnostic diagnostic-${diagnostic.severity}`;
        const explanation = explainDiagnostic(diagnostic);
        const severity = document.createElement("span");
        severity.className = "diagnostic-severity";
        severity.textContent = diagnostic.severity;
        const heading = document.createElement("strong");
        heading.textContent = explanation.title;
        const message = document.createElement("p");
        message.textContent = diagnostic.message;
        item.append(severity, heading, message, renderDiagnosticExplanation(explanation));
        list.append(item);
      }
      section.append(list);
      return section;
    }

    function analysisSection(title: string) {
      const section = document.createElement("section");
      section.className = "analysis-section";
      const heading = document.createElement("h3");
      heading.textContent = title;
      section.append(heading);
      return section;
    }

    function analysisCheck(state: "pass" | "warn" | "info", title: string, detail: string) {
      const item = document.createElement("li");
      item.className = `analysis-check analysis-check-${state}`;
      const marker = document.createElement("span");
      marker.textContent = state === "pass" ? "✓" : state === "warn" ? "!" : "i";
      const copy = document.createElement("div");
      const strong = document.createElement("strong");
      strong.textContent = title;
      const paragraph = document.createElement("p");
      paragraph.textContent = detail;
      copy.append(strong, paragraph);
      item.append(marker, copy);
      return item;
    }

    function analysisInsight(text: string) {
      const item = document.createElement("li");
      item.textContent = text;
      return item;
    }

    function lifecycleParticipation(capability: CapabilitySummary, rawCapability: AnalysisCapability | undefined) {
      const items = [
        capability.lifecycle?.begin ? `Begin: ${capability.lifecycle.begin}` : undefined,
        ...(capability.lifecycle?.steps?.map((step) => `Step: ${step}`) ?? []),
        ...(capability.lifecycle?.transitions?.map((transition) => `Transition: ${transition}`) ?? []),
        ...(capability.lifecycle?.ends?.map((end) => `End: ${end}`) ?? []),
        ...(namesFromUnknownItems(rawCapability?.lifecycle?.participating_capabilities).map((item) => `Participates with ${item}`) ?? []),
        ...(namesFromUnknownItems(rawCapability?.lifecycle?.contributors).map((item) => `Contributor: ${item}`) ?? []),
      ].filter((item): item is string => Boolean(item));
      return items.length ? items : undefined;
    }

    function formatOutcomeCause(cause: unknown) {
      if (!isObject(cause)) return String(cause);
      const outcome = stringValue(cause.outcome) ?? "outcome";
      const source = stringValue(cause.source);
      const condition = stringValue(cause.condition);
      const precedence = typeof cause.precedence === "number" ? `, precedence ${cause.precedence}` : "";
      return [outcome, source ? `from ${source}` : undefined, condition ? `when ${condition}` : undefined].filter(Boolean).join(" ") + precedence;
    }

    function namesFromUnknownItems(items: unknown[] | undefined) {
      if (!Array.isArray(items)) return [];
      return items.map(nameFromUnknownItem).filter((item): item is string => Boolean(item));
    }

    function nameFromUnknownItem(item: unknown) {
      if (typeof item === "string") return item;
      if (!isObject(item)) return undefined;
      return stringValue(item.name) ?? stringValue(item.actor) ?? stringValue(item.capability) ?? stringValue(item.event) ?? stringValue(item.effect);
    }

    function appendDefinition(parent: HTMLDListElement, termText: string, detailText: string) {
      const term = document.createElement("dt");
      term.textContent = termText;
      const detail = document.createElement("dd");
      detail.textContent = detailText;
      parent.append(term, detail);
    }

    function countUnique(items: string[]) {
      return new Set(items).size;
    }

    function maxBy<T>(items: T[], score: (item: T) => number): T | undefined {
      return items.reduce<T | undefined>((best, item) => (best === undefined || score(item) > score(best) ? item : best), undefined);
    }

    function stringValue(value: unknown) {
      return typeof value === "string" && value ? value : undefined;
    }

    function isObject(value: unknown): value is Record<string, unknown> {
      return Boolean(value) && typeof value === "object";
    }

    function flowHeading() {
      const heading = document.createElement("h2");
      heading.textContent = "Flow";
      return heading;
    }

    function flowIntro() {
      const intro = document.createElement("p");
      intro.className = "summary-intro";
      intro.textContent = "Lifecycle transitions and emitted events derived from the compiler summary.";
      return intro;
    }

    function hasFlow(capability: CapabilitySummary) {
      return Boolean(
        capability.lifecycle?.begin ||
          capability.lifecycle?.ends?.length ||
          capability.lifecycle?.steps?.length ||
          capability.lifecycle?.transitions?.length ||
          capability.events?.length,
      );
    }

    function renderFlowCard(capability: CapabilitySummary) {
      const card = document.createElement("article");
      card.className = "flow-card";

      const heading = document.createElement("h3");
      heading.textContent = capability.name;
      card.append(heading);

      if (capability.lifecycle?.begin) {
        appendFlowSection(card, "Begin step", [capability.lifecycle.begin]);
      }
      appendFlowTimeline(card, capability);
      appendFlowSection(card, "Lifecycle steps", capability.lifecycle?.steps);
      appendFlowSection(card, "End steps", capability.lifecycle?.ends);
      appendFlowSection(card, "Emitted events", capability.events);

      return card;
    }

    function appendFlowTimeline(parent: HTMLElement, capability: CapabilitySummary) {
      if (!capability.lifecycle?.transitions?.length) return;

      const section = document.createElement("section");
      section.className = "flow-section";
      const heading = document.createElement("strong");
      heading.textContent = "Timeline";
      const timeline = document.createElement("ol");
      timeline.className = "flow-timeline";

      for (const transition of capability.lifecycle.transitions) {
        const item = document.createElement("li");
        item.textContent = transition;
        timeline.append(item);
      }

      section.append(heading, timeline);
      parent.append(section);
    }

    function appendFlowSection(parent: HTMLElement, title: string, items?: string[]) {
      if (!items?.length) return;

      const section = document.createElement("section");
      section.className = "flow-section";
      const heading = document.createElement("strong");
      heading.textContent = title;
      section.append(heading, renderValueList(items));
      parent.append(section);
    }

    function appendMapSection(parent: HTMLElement, title: string, items?: string[]) {
      if (!items?.length) return;

      const section = document.createElement("section");
      section.className = "capability-map-section";

      const heading = document.createElement("strong");
      heading.textContent = title;
      section.append(heading, renderValueList(items));
      parent.append(section);
    }

    function renderSummaryGroup(labelText: string, items?: string[]) {
      const group = document.createElement("div");
      group.className = "summary-group";
      if (!items?.length) {
        group.setAttribute("hidden", "");
        return group;
      }

      const label = document.createElement("strong");
      label.textContent = labelText;
      group.append(label, renderValueList(items));
      return group;
    }

    function renderInlineList(label: string, items: string[]) {
      const wrapper = document.createElement("div");
      wrapper.className = "summary-inline-list";
      const strong = document.createElement("span");
      strong.textContent = `${label}:`;
      wrapper.append(strong, renderValueList(items));
      return wrapper;
    }

    function renderValueList(items: string[]) {
      const list = document.createElement("ul");
      for (const item of items) {
        const element = document.createElement("li");
        element.textContent = item;
        list.append(element);
      }
      return list;
    }

    function renderVisuals(summary: SemanticSummary, compileDiagnostics: Awaited<ReturnType<typeof compileDcl>>["diagnostics"]) {
      const model = createVisualModel(summary, compileDiagnostics);
      selectedVisualCapabilityId = model.capabilities[0]?.id ?? "";
      if (visualsStatus) {
        visualsStatus.textContent = model.capabilities.length
          ? `Showing ${model.capabilities.length} ${model.capabilities.length === 1 ? "capability" : "capabilities"} across ${model.contexts.length} ${model.contexts.length === 1 ? "context" : "contexts"}.`
          : "No capabilities found.";
      }

      renderContextHeatMap(model);
      renderVisualCapabilityFlow(model);
      renderVisualLifecycleFlow(model);
      activateVisualPanel("heatmap");
    }

    function renderVisualEmpty(message: string) {
      if (visualsStatus) visualsStatus.textContent = message;
      for (const panel of visualPanels) {
        const empty = document.createElement("p");
        empty.className = "visual-empty";
        empty.textContent = message;
        panel.replaceChildren(empty);
      }
      selectedVisualCapabilityId = "";
      activateVisualPanel("heatmap");
    }

    function renderContextHeatMap(model: VisualModel) {
      if (!heatMapOutput) return;
      if (model.capabilities.length === 0) {
        heatMapOutput.replaceChildren(visualEmpty("No capabilities found."));
        return;
      }

      const layout = document.createElement("div");
      layout.className = "context-heatmap-layout";
      const grid = document.createElement("div");
      grid.className = "context-heatmap-grid";
      const details = document.createElement("aside");
      details.className = "visual-details-panel";
      details.setAttribute("aria-live", "polite");
      details.dataset.visualDetails = "capability";

      for (const context of model.contexts) {
        grid.append(renderContextPanel(context, model));
      }

      layout.append(grid, details);
      heatMapOutput.replaceChildren(layout);
      updateVisualSelection(model, selectedVisualCapabilityId);
    }

    function renderContextPanel(context: VisualContext, model: VisualModel) {
      const panel = document.createElement("section");
      panel.className = "visual-context-panel";

      const heading = document.createElement("div");
      heading.className = "visual-context-heading";
      const title = document.createElement("h3");
      title.textContent = context.name;
      const meta = document.createElement("span");
      meta.textContent = `${context.capabilities.length} ${context.capabilities.length === 1 ? "capability" : "capabilities"}`;
      heading.append(title, meta);
      panel.append(heading);

      if (context.dependencies.length) {
        const deps = document.createElement("div");
        deps.className = "visual-dependencies";
        const label = document.createElement("span");
        label.textContent = "depends on";
        deps.append(label);
        for (const dependency of context.dependencies) {
          const badge = document.createElement("span");
          badge.className = "visual-dependency-badge";
          badge.textContent = dependency;
          deps.append(badge);
        }
        panel.append(deps);
      }

      const tiles = document.createElement("div");
      tiles.className = "visual-capability-tiles";
      for (const capability of context.capabilities) {
        tiles.append(renderCapabilityTile(capability, model));
      }
      panel.append(tiles);
      return panel;
    }

    function renderCapabilityTile(capability: VisualCapability, model: VisualModel) {
      const tile = document.createElement("button");
      tile.className = `visual-capability-tile heat-${capability.heatLevel}`;
      tile.type = "button";
      tile.dataset.capabilityId = capability.id;
      tile.setAttribute("aria-pressed", String(capability.id === selectedVisualCapabilityId));

      const title = document.createElement("strong");
      title.textContent = capability.name;
      const score = document.createElement("span");
      score.className = "visual-score";
      score.textContent = `Complexity ${capability.complexityScore}`;
      const header = document.createElement("span");
      header.className = "visual-tile-header";
      header.append(title, score);
      tile.append(header);

      if (capability.diagnostics.length) {
        const diagnosticBadge = document.createElement("span");
        diagnosticBadge.className = "visual-diagnostic-badge";
        diagnosticBadge.textContent = `${capability.diagnostics.length} diagnostic${capability.diagnostics.length === 1 ? "" : "s"}`;
        tile.append(diagnosticBadge);
      }

      tile.addEventListener("click", () => updateVisualSelection(model, capability.id, { reveal: true }));
      return tile;
    }

    function updateVisualSelection(model: VisualModel, capabilityId: string, options: { reveal?: boolean } = {}) {
      const capability = model.capabilities.find((item) => item.id === capabilityId) ?? model.capabilities[0];
      selectedVisualCapabilityId = capability?.id ?? "";

      heatMapOutput?.querySelectorAll<HTMLButtonElement>("[data-capability-id]").forEach((tile) => {
        const selected = tile.dataset.capabilityId === selectedVisualCapabilityId;
        tile.classList.toggle("is-selected", selected);
        tile.setAttribute("aria-pressed", String(selected));
      });

      const details = heatMapOutput?.querySelector<HTMLElement>("[data-visual-details='capability']");
      if (!details || !capability) return;
      details.replaceChildren(renderCapabilityDetails(capability));
      if (options.reveal) revealVisualLocation(capability.location);
    }

    function renderCapabilityDetails(capability: VisualCapability) {
      const wrapper = document.createElement("div");
      wrapper.className = "visual-details";
      const heading = document.createElement("div");
      heading.className = "visual-details-heading";
      const title = document.createElement("h3");
      title.textContent = capability.name;
      const context = document.createElement("span");
      context.textContent = capability.contextName;
      heading.append(title, context);
      wrapper.append(heading);

      const summary = document.createElement("p");
      summary.className = "visual-details-summary";
      summary.textContent = `Complexity ${capability.complexityScore}, based on declared DCL primitives.`;
      wrapper.append(summary);
      wrapper.append(renderRevealSourceAction(capability.location));

      if (capability.diagnostics.length) {
        const diagnosticsList = document.createElement("div");
        diagnosticsList.className = "visual-detail-group visual-detail-diagnostics";
        const label = document.createElement("strong");
        label.textContent = "Diagnostics";
        diagnosticsList.append(label, renderValueList(capability.diagnostics.map((diagnostic) => `${diagnostic.severity}: ${diagnostic.message}`)));
        wrapper.append(diagnosticsList);
      }

      appendDetailGroup(wrapper, capability, "Intents", "intents", capability.summary.intents);
      appendDetailGroup(wrapper, capability, "Actors", "actors", capability.summary.actors);
      appendDetailGroup(wrapper, capability, "Outcomes", "outcomes", capability.summary.outcomes);
      appendDetailGroup(wrapper, capability, "Rules", "rules", capability.summary.rules);
      appendDetailGroup(wrapper, capability, "Effects", "effects", capability.summary.effects);
      appendDetailGroup(wrapper, capability, "Events", "events", capability.summary.events);
      appendDetailGroup(wrapper, capability, "Policies", "policies", capability.summary.policies);

      const lifecycle = [
        capability.summary.lifecycle?.begin ? `Begin: ${capability.summary.lifecycle.begin}` : undefined,
        ...(capability.summary.lifecycle?.steps?.map((step) => `Step: ${step}`) ?? []),
        ...(capability.summary.lifecycle?.transitions?.map((transition) => `Move: ${transition}`) ?? []),
        ...(capability.summary.lifecycle?.ends?.map((end) => `End: ${end}`) ?? []),
      ].filter((item): item is string => Boolean(item));
      appendDetailGroup(wrapper, capability, "Lifecycle", "lifecycle", lifecycle);

      return wrapper;
    }

    function renderRevealSourceAction(location: SourceLocation | undefined) {
      const action = document.createElement("div");
      action.className = "visual-source-action";

      if (hasSourceLocation(location)) {
        const button = document.createElement("button");
        button.className = "visual-source-button";
        button.type = "button";
        button.textContent = "Reveal in source";
        button.addEventListener("click", () => revealVisualLocation(location));
        action.append(button);
        return action;
      }

      const fallback = document.createElement("p");
      fallback.className = "visual-source-unavailable";
      fallback.textContent = "Source location is not available for this item yet.";
      action.append(fallback);
      return action;
    }

    function appendDetailGroup(parent: HTMLElement, capability: VisualCapability, labelText: string, kind: CapabilityItemKind, items?: string[]) {
      if (!items?.length) return;
      const group = document.createElement("section");
      group.className = "visual-detail-group";
      const label = document.createElement("strong");
      label.textContent = labelText;
      group.append(label, renderVisualDetailItems(capability, kind, items));
      parent.append(group);
    }

    function renderVisualDetailItems(capability: VisualCapability, kind: CapabilityItemKind, items: string[]) {
      const list = document.createElement("ul");
      for (const item of items) {
        const element = document.createElement("li");
        const label = document.createElement("span");
        label.textContent = item;
        element.append(label);

        const location = capability.summary.itemLocations?.[kind]?.[item];
        if (hasSourceLocation(location)) {
          const button = document.createElement("button");
          button.className = "visual-inline-source-button";
          button.type = "button";
          button.textContent = "Reveal";
          button.addEventListener("click", () => revealVisualLocation(location));
          element.append(button);
        } else {
          const fallback = document.createElement("span");
          fallback.className = "visual-inline-source-unavailable";
          fallback.textContent = "Source location is not available for this item yet.";
          element.append(fallback);
        }

        list.append(element);
      }
      return list;
    }

    function revealVisualLocation(location: SourceLocation | undefined) {
      if (!hasSourceLocation(location)) return false;
      return sourceEditor.revealSourceLocation(location);
    }

    function hasSourceLocation(location: SourceLocation | undefined): location is SourceLocation & { line: number } {
      return Boolean(location && Number.isInteger(location.line) && location.line > 0);
    }

    function renderVisualCapabilityFlow(model: VisualModel) {
      if (!visualCapabilityFlowOutput) return;
      if (model.capabilities.length === 0) {
        visualCapabilityFlowOutput.replaceChildren(visualEmpty("No capabilities found."));
        return;
      }

      const list = document.createElement("div");
      list.className = "visual-flow-list";
      for (const capability of model.capabilities) {
        const card = document.createElement("article");
        card.className = "visual-flow-card";
        const title = document.createElement("h3");
        title.textContent = capability.name;
        const context = document.createElement("span");
        context.textContent = capability.contextName;
        card.append(title, context);
        appendFlowLane(card, "Intent", capability.summary.intents);
        appendFlowLane(card, "Rules", capability.summary.rules);
        appendFlowLane(card, "Outcomes", capability.summary.outcomes);
        appendFlowLane(card, "Effects & events", [...(capability.summary.effects ?? []), ...(capability.summary.events ?? [])]);
        list.append(card);
      }
      visualCapabilityFlowOutput.replaceChildren(list);
    }

    function renderVisualLifecycleFlow(model: VisualModel) {
      if (!visualLifecycleFlowOutput) return;
      const flowCapabilities = model.capabilities.filter((capability) =>
        Boolean(capability.summary.lifecycle?.begin || capability.summary.lifecycle?.steps?.length || capability.summary.lifecycle?.transitions?.length || capability.summary.events?.length),
      );
      if (flowCapabilities.length === 0) {
        visualLifecycleFlowOutput.replaceChildren(visualEmpty("No lifecycle or event flow found."));
        return;
      }

      const list = document.createElement("div");
      list.className = "visual-flow-list";
      for (const capability of flowCapabilities) {
        const card = document.createElement("article");
        card.className = "visual-flow-card";
        const title = document.createElement("h3");
        title.textContent = capability.name;
        const context = document.createElement("span");
        context.textContent = capability.contextName;
        card.append(title, context);
        appendFlowLane(card, "Begin", capability.summary.lifecycle?.begin ? [capability.summary.lifecycle.begin] : undefined);
        appendFlowLane(card, "Steps", capability.summary.lifecycle?.steps);
        appendFlowLane(card, "Transitions", capability.summary.lifecycle?.transitions);
        appendFlowLane(card, "Events", capability.summary.events);
        list.append(card);
      }
      visualLifecycleFlowOutput.replaceChildren(list);
    }

    function appendFlowLane(parent: HTMLElement, labelText: string, items?: string[]) {
      if (!items?.length) return;
      const lane = document.createElement("section");
      lane.className = "visual-flow-lane";
      const label = document.createElement("strong");
      label.textContent = labelText;
      const values = document.createElement("div");
      values.className = "visual-flow-values";
      for (const item of items) {
        const chip = document.createElement("span");
        chip.textContent = item;
        values.append(chip);
      }
      lane.append(label, values);
      parent.append(lane);
    }

    function visualEmpty(message: string) {
      const empty = document.createElement("p");
      empty.className = "visual-empty";
      empty.textContent = message;
      return empty;
    }

    function activateVisualPanel(view: string) {
      for (const tab of visualTabs) {
        const selected = tab.dataset.visualTab === view;
        tab.setAttribute("aria-selected", String(selected));
      }

      for (const panel of visualPanels) {
        if (panel.dataset.visualPanel === view) {
          panel.removeAttribute("hidden");
        } else {
          panel.setAttribute("hidden", "");
        }
      }
    }

    function renderAdvancedOutput(result: Awaited<ReturnType<typeof compileDcl>>) {
      if (!advancedOutput || !compilerOutput) return;

      if (!result.ir) {
        compilerOutput.textContent = "{}";
        return;
      }

      compilerOutput.textContent = JSON.stringify(result.ir, null, 2);
    }

    async function copyText(text: string, button: HTMLButtonElement | null, successLabel: string) {
      if (!button) return;
      const original = button.textContent ?? "";
      try {
        await navigator.clipboard.writeText(text);
        button.textContent = successLabel;
      } catch {
        const fallback = document.createElement("textarea");
        fallback.value = text;
        fallback.setAttribute("readonly", "");
        fallback.style.position = "fixed";
        fallback.style.opacity = "0";
        document.body.append(fallback);
        fallback.select();
        document.execCommand("copy");
        fallback.remove();
        button.textContent = successLabel;
      } finally {
        window.setTimeout(() => {
          button.textContent = original;
        }, 1400);
      }
    }

    function activateResultPanel(view: string) {
      for (const tab of resultTabs) {
        const selected = tab.dataset.resultTab === view;
        tab.setAttribute("aria-selected", String(selected));
      }

      for (const panel of resultPanels) {
        if (panel.dataset.resultPanel === view) {
          panel.removeAttribute("hidden");
        } else {
          panel.setAttribute("hidden", "");
        }
      }
    }

    function loadExample(options: { updateUrl?: boolean } = {}) {
      const example = selectedExample();

      sourceEditor.setValue(example.source);
      sourceEditor.setDiagnostics([]);
      if (summary) summary.textContent = example.description;
      if (sourcePath) sourcePath.innerHTML = `Source: <code>${example.path}</code>`;
      if (diagnostics) diagnostics.innerHTML = "<p>No compile run yet.</p>";
      if (diagnosticsCount) diagnosticsCount.textContent = "No run";
      if (compilerResults) compilerResults.setAttribute("hidden", "");
      if (summaryOutput) summaryOutput.replaceChildren();
      if (mapOutput) mapOutput.replaceChildren();
      if (flowOutput) flowOutput.replaceChildren();
      if (analysisOutput) analysisOutput.replaceChildren();
      if (compilerOutput) compilerOutput.textContent = "{}";
      activateResultPanel("summary");
      renderVisualEmpty("Compile DCL source to generate visuals.");

      if (options.updateUrl) updateExampleUrl();
      setStatus("Ready. Example loaded from validated website source.");
    }

    function clearCompileOutput(message: string) {
      sourceEditor.setDiagnostics([]);
      if (diagnostics) diagnostics.innerHTML = "<p>No compile run yet.</p>";
      if (diagnosticsCount) diagnosticsCount.textContent = "No run";
      if (compilerResults) compilerResults.setAttribute("hidden", "");
      if (summaryOutput) summaryOutput.replaceChildren();
      if (mapOutput) mapOutput.replaceChildren();
      if (flowOutput) flowOutput.replaceChildren();
      if (analysisOutput) analysisOutput.replaceChildren();
      if (compilerOutput) compilerOutput.textContent = "{}";
      activateResultPanel("summary");
      renderVisualEmpty("Compile DCL source to generate visuals.");
      setStatus(message);
    }

    select?.addEventListener("change", () => loadExample({ updateUrl: true }));
    resetButton?.addEventListener("click", () => loadExample({ updateUrl: true }));
    formatSourceButton?.addEventListener("click", () => {
      const changed = sourceEditor.formatSource();
      clearCompileOutput(changed ? "Source formatted. Compile again to refresh diagnostics." : "Source already formatted.");
    });
    showSuggestionsButton?.addEventListener("click", () => sourceEditor.showSuggestions());
    copySourceButton?.addEventListener("click", () => copyText(sourceEditor.getValue(), copySourceButton, "Copied"));
    copyDiagnosticsButton?.addEventListener("click", () =>
      copyText(diagnostics?.textContent?.trim() || "No diagnostics.", copyDiagnosticsButton, "Copied"),
    );
    copyPlaygroundLinkButton?.addEventListener("click", () =>
      copyText(currentPlaygroundLink(), copyPlaygroundLinkButton, "Copied"),
    );
    resultTabs.forEach((tab) => {
      tab.addEventListener("click", () => activateResultPanel(tab.dataset.resultTab ?? "summary"));
    });
    visualTabs.forEach((tab) => {
      tab.addEventListener("click", () => activateVisualPanel(tab.dataset.visualTab ?? "heatmap"));
    });

    compileButton?.addEventListener("click", async () => {
      setStatus("Compiling...", "pending");
      sourceEditor.setDiagnostics([]);

      const result = await compileDcl(sourceEditor.getValue());
      sourceEditor.setDiagnostics(result.diagnostics);
      renderDiagnostics(result);
      renderSummary(result);
      renderAdvancedOutput(result);

      if (result.ok) {
        const hasWarnings = result.diagnostics.some((diagnostic) => diagnostic.severity === "warning");
        setStatus(hasWarnings ? "Compiled with warnings." : "Compile succeeded.", hasWarnings ? "warning" : "success");
        return;
      }

      const hasErrors = result.diagnostics.some((diagnostic) => diagnostic.severity === "error");
      const compilerUnavailable = result.diagnostics.some(
        (diagnostic) => diagnostic.code === "DCL_PLAYGROUND_COMPILER_UNAVAILABLE",
      );
      setStatus(
        compilerUnavailable ? "Browser compiler unavailable." : hasErrors ? "Compile failed." : "Compile completed with diagnostics.",
        hasErrors ? "error" : "pending",
      );
    });

    if (selectExampleFromUrl()) {
      loadExample();
    }
  </script>
</BaseLayout>
